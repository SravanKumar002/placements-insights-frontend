# Copy to `.env` (never commit `.env`). Vite only exposes variables prefixed with VITE_.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public Placement API base URL (no trailing slash)
VITE_PLACEMENT_API_URL=https://placements-insights-backend.onrender.com

# Optional / feature-specific
VITE_GEMINI_API_KEY=
VITE_BRANDFETCH_CLIENT_ID=

# "true" = no NxtWave SSO gate; visitors use the app as student until admin signs in
# VITE_OPEN_STUDENT_ACCESS=true
